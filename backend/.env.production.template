# Production Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ==========================================
# Node Environment
# ==========================================
NODE_ENV=production

# ==========================================
# Server Configuration
# ==========================================
PORT=3001

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/whatsapp_crm?schema=public"
# Example: postgresql://postgres:secure_password@db.render.com:5432/whatsapp_crm?schema=public

# ==========================================
# Security Configuration
# ==========================================
# Generate a secure JWT secret (at least 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# JWT token expiration time
JWT_EXPIRES_IN="24h"

# Bcrypt password hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ==========================================
# WhatsApp Cloud API Configuration
# ==========================================
# Get these from Meta Business Settings: https://business.facebook.com/settings/
WA_VERIFY_TOKEN=""  # Your webhook verification token
META_API_VERSION="v20.0"

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
CORS_ORIGIN="https://yourdomain.com,https://app.yourdomain.com"

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# ==========================================
# Logging
# ==========================================
LOG_LEVEL=warn  # debug, info, warn, error

# ==========================================
# Default Workspace (for testing)
# ==========================================
DEFAULT_WORKSPACE_ID=""
