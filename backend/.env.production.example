# Production Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/whatsapp_crm?schema=public"
# Example: postgresql://postgres:mypassword@db.render.com:5432/whatsapp_crm?schema=public

# Alternative for local development with Docker:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/whatsapp_crm?schema=public"

# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=production
PORT=3001

# ==========================================
# WhatsApp Cloud API Configuration
# ==========================================
# Get these from Meta Developer Dashboard: https://developers.facebook.com/
WA_VERIFY_TOKEN="your_secure_random_string_here"
META_API_VERSION="v20.0"

# Optional: If you have a specific WhatsApp Business Account
# WHATSAPP_BUSINESS_ACCOUNT_ID="your_waba_id"

# ==========================================
# Security Configuration
# ==========================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"

# CORS Origins (comma-separated)
CORS_ORIGIN="https://yourdomain.com,https://www.yourdomain.com"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Redis Configuration (Optional but recommended)
# ==========================================
# REDIS_URL="redis://localhost:6379"
# Or for cloud Redis:
# REDIS_URL="redis://username:password@your-redis-host:6379"

# ==========================================
# Monitoring & Logging
# ==========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# ==========================================
# Email Configuration (for notifications)
# ==========================================
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT=587
# SMTP_USER="apikey"
# SMTP_PASS="your_sendgrid_api_key"
# FROM_EMAIL="noreply@yourdomain.com"

# ==========================================
# Cloud Storage (for media files)
# ==========================================
# AWS_S3_BUCKET="your-bucket-name"
# AWS_S3_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your_access_key"
# AWS_SECRET_ACCESS_KEY="your_secret_key"

# Or use Cloudflare R2:
# R2_BUCKET="your-bucket"
# R2_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
