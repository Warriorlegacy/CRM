generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  name              String?
  email             String            @unique
  password          String
  active            Boolean           @default(true)
  emailVerified     Boolean           @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ownedWorkspaces   Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers  WorkspaceMember[]
  assignedContacts  Contact[]         @relation("ContactAssignee")
  sentMessages      Message[]         @relation("MessageSender")
  followupsAssigned Followup[]        @relation("FollowupAssignee")
  typingStatuses    TypingIndicator[]
  readReceipts      ReadReceipt[]
  verificationTokens VerificationToken[]
  conversationNotes ConversationNote[]
  agentActivities   AgentActivity[]   @relation("AgentActivities")
}

model Workspace {
  id                  String            @id @default(uuid())
  name                String
  slug                String            @unique
  ownerId             String
  plan                String            @default("free")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  businessHoursEnabled Boolean          @default(false)
  businessHoursJson   String?
  owner               User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members             WorkspaceMember[]
  wa                  WaAccount?
  ig                  IgAccount?
  contacts            Contact[]
  conversations       Conversation[]
  messages            Message[]
  followups           Followup[]
  templates           Template[]
  broadcasts          Broadcast[]
  awayMessages        AwayMessage[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  userId      String
  role        String    @default("agent")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WaAccount {
  id                 String    @id @default(uuid())
  workspaceId        String    @unique
  phoneNumberId      String
  businessAccountId  String
  accessToken        String
  webhookVerifyToken String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model IgAccount {
  id                 String    @id @default(uuid())
  workspaceId        String    @unique
  igUserId           String
  accessToken        String
  webhookVerifyToken String
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Contact {
  id             String         @id @default(uuid())
  workspaceId    String
  name           String?
  phone          String
  email          String?
  igUsername      String?
  profilePicture String?
  tags           String         @default("")
  stage          String         @default("new")
  leadScore      Int            @default(0)
  channel        String         @default("whatsapp")
  assignedToId   String?
  lastMessageAt  DateTime?
  unreadCount    Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedTo     User?          @relation("ContactAssignee", fields: [assignedToId], references: [id])
  conversations  Conversation[]
  messages       Message[]
  followups      Followup[]
  flowExecutions FlowExecution[]
  broadcastMessages BroadcastMessage[]

  @@unique([workspaceId, phone])
  @@index([workspaceId, stage])
  @@index([assignedToId])
  @@index([igUsername])
  @@index([channel])
  @@index([email])
  @@index([lastMessageAt])
}

model Conversation {
  id                 String            @id @default(uuid())
  workspaceId        String
  contactId          String
  channel            String            @default("whatsapp")
  status             String            @default("open")
  lastReadAt         DateTime?
  lockedByUserId     String?
  lockedAt           DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  tags               String           @default("[]")
  lastKnownLanguage  String?            @default("en")
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact            Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages           Message[]
  typingUsers        TypingIndicator[]
  tagAssignments     ConversationTagAssignment[] @relation("ConversationTagAssignments")
  activities         AgentActivity[]
  notes              ConversationNote[] @relation("ConversationNotes")

  @@unique([workspaceId, contactId])
  @@index([workspaceId])
  @@index([contactId])
  @@index([channel])
  @@index([workspaceId, status])
  @@index([workspaceId, updatedAt])
}

model TypingIndicator {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  workspaceId    String
  status         String       @default("idle")
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([updatedAt])
}

model Message {
  id             String        @id @default(uuid())
  workspaceId    String
  conversationId String
  contactId      String
  channel        String        @default("whatsapp")
  direction      String
  type           String        @default("text")
  bodyText       String?
  waMessageId    String?
  igMessageId    String?
  mediaUrl       String?
  mediaType      String?
  mediaMimeType  String?
  sentByUserId   String?
  readAt         DateTime?
  createdAt      DateTime      @default(now())
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  sentByUser     User?         @relation("MessageSender", fields: [sentByUserId], references: [id])
  readReceipts   ReadReceipt[]

  @@index([workspaceId, createdAt])
  @@index([conversationId, createdAt])
  @@index([contactId, createdAt])
  @@index([waMessageId])
  @@index([igMessageId])
  @@index([direction])
  @@index([sentByUserId])
}

model ReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model Followup {
  id           String    @id @default(uuid())
  workspaceId  String
  contactId    String
  assignedToId String?
  dueAt        DateTime
  note         String?
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedTo   User?     @relation("FollowupAssignee", fields: [assignedToId], references: [id])

  @@index([workspaceId, status, dueAt])
  @@index([assignedToId])
}

model Template {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  body        String
  category    String    @default("utility")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model ContactNote {
  id          String   @id @default(uuid())
  workspaceId String
  contactId   String
  userId      String
  content     String
  category    String   @default("general")
  channel     String?
  type        String   @default("note")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([contactId])
}

model ConversationNote {
  id             String   @id @default(uuid())
  workspaceId    String
  conversationId String
  userId         String
  content        String
  priority       String   @default("normal")
  mentions       String @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation   Conversation @relation("ConversationNotes", fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([workspaceId, conversationId, createdAt])
}

model Autoresponder {
  id           String   @id @default(uuid())
  workspaceId  String
  name         String
  trigger      String
  keyword      String?
  delayMinutes Int      @default(0)
  message      String
  isActive     Boolean  @default(true)
  stages       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workspaceId])
  @@index([isActive])
}

model PendingAutoresponse {
  id             String   @id @default(uuid())
  workspaceId    String
  contactId      String
  conversationId String
  message        String
  sendAt         DateTime
  sent           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([sendAt, sent])
  @@index([workspaceId])
}

model WebhookLog {
  id          String   @id @default(uuid())
  workspaceId String
  type        String
  payload     String
  status      String   @default("success")
  error       String?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([type])
  @@index([createdAt])
}

model ChatbotFlow {
  id             String           @id @default(uuid())
  workspaceId    String
  name           String
  description    String?
  isActive       Boolean          @default(true)
  trigger        String           @default("keyword")
  triggerKeyword String?
  channels       String           @default("whatsapp,instagram")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  nodes          FlowNode[]
  edges          FlowEdge[]
  executions     FlowExecution[]

  @@index([workspaceId])
  @@index([isActive])
}

model FlowNode {
  id         String      @id @default(uuid())
  flowId     String
  type       String
  label      String?
  content    String?
  positionX  Float       @default(0)
  positionY  Float       @default(0)
  config     String?
  createdAt  DateTime    @default(now())
  flow       ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  outEdges   FlowEdge[]  @relation("SourceNode")
  inEdges    FlowEdge[]  @relation("TargetNode")

  @@index([flowId])
}

model FlowEdge {
  id        String     @id @default(uuid())
  flowId    String
  sourceId  String
  targetId  String
  label     String?
  condition String?
  source    FlowNode   @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  target    FlowNode   @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)
  flow      ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([sourceId])
  @@index([targetId])
}

model FlowExecution {
  id            String      @id @default(uuid())
  flowId        String
  contactId     String
  currentNodeId String?
  status        String      @default("active")
  context       String?
  startedAt     DateTime    @default(now())
  completedAt   DateTime?
  flow          ChatbotFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([contactId])
  @@index([status])
}

model LeadScoringRule {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  event       String
  points      Int      @default(1)
  conditions  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

model AiProvider {
  id             String   @id @default(uuid())
  workspaceId    String
  name           String
  provider       String
  apiKey         String
  baseUrl        String?
  model          String
  priority       Int      @default(0)
  isActive       Boolean  @default(true)
  maxTokens      Int      @default(1024)
  temperature    Float    @default(0.7)
  lastUsedAt     DateTime?
  lastErrorAt    DateTime?
  errorCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model AiConversationSummary {
  id             String   @id @default(uuid())
  workspaceId    String
  conversationId String
  summary        String
  sentiment      String?
  keyTopics      String?
  nextSteps      String?
  createdAt      DateTime @default(now())

  @@index([workspaceId])
  @@index([conversationId])
}

model AiAutoReplyLog {
  id              String   @id @default(uuid())
  workspaceId     String
  conversationId  String
  contactId       String
  incomingMessage String
  aiReply         String
  provider        String
  model           String
  latencyMs       Int?
  confidence      Float?
  wasSent         Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([workspaceId])
  @@index([conversationId])
  @@index([createdAt])
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model AwayMessage {
  id          String   @id @default(uuid())
  workspaceId String
  message     String
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  showWhenNoAgent Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([workspaceId, isActive, priority])
}

model Broadcast {
  id              String          @id @default(uuid())
  workspaceId     String
  name            String
  message         String
  recipientFilter String?
  status          String          @default("draft")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int             @default(0)
  sentCount       Int             @default(0)
  deliveredCount  Int             @default(0)
  failedCount     Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages        BroadcastMessage[]

  @@index([workspaceId])
  @@index([status])
}

model BroadcastMessage {
  id          String    @id @default(uuid())
  broadcastId String
  contactId   String
  status      String    @default("pending")
  waMessageId String?
  error       String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
  @@index([contactId])
  @@index([status])
}

model ConversationTag {
  id          String                   @id @default(uuid())
  workspaceId String
  name        String
  color       String                   @default("#6366f1")
  description String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  assignments ConversationTagAssignment[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ConversationTagAssignment {
  id             String        @id @default(uuid())
  workspaceId    String?
  conversationId String
  tagId          String
  assignedAt     DateTime      @default(now())
  tag            ConversationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  conversation   Conversation  @relation("ConversationTagAssignments", fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
  @@index([tagId])
  @@index([conversationId])
  @@index([workspaceId])
}

model AgentActivity {
  id             String      @id @default(uuid())
  workspaceId    String
  userId         String
  action         String
  conversationId String
  createdAt      DateTime    @default(now())

  user           User         @relation("AgentActivities", fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId, conversationId, createdAt])
  @@index([userId])
}
